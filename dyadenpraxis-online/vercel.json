{
  "redirects": [
    { "source": "/dyade-meditation", "destination": "/dyaden-meditation", "permanent": true }
  ],
  "rewrites": [
    { "source": "/impressum", "destination": "/impressum.html" },
    { "source": "/datenschutz", "destination": "/datenschutz.html" },
    { "source": "/dyaden-meditation", "destination": "/dyaden-meditation.html" },
    { "source": "/tools", "destination": "/tools/index.html" },
    { "source": "/tools/dyaden-fragen-generator", "destination": "/tools/dyaden-fragen-generator.html" },
    { "source": "/tools/check-in-fragen-paare", "destination": "/tools/check-in-fragen-paare.html" },
    { "source": "/tools/konflikt-reflexion", "destination": "/tools/konflikt-reflexion.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(), payment=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: blob: https://dyadenpraxis.de; connect-src 'self' https://*.supabase.co https://api.daily.co wss://*.supabase.co https://generativelanguage.googleapis.com; media-src blob: https://*.daily.co; frame-src https://*.daily.co; manifest-src 'self'" }
      ]
    },
    {
      "source": "/(calendar|profile|connect|groups|partner-finder|instructions|reset-password|session|agb)(/.*)?",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "application/xml; charset=utf-8" }
      ]
    },
    {
      "source": "/llms.txt",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "Content-Type", "value": "text/plain; charset=utf-8" }
      ]
    }
  ]
}
